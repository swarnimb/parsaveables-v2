# Frontend (Vite — must be prefixed VITE_ to be exposed to the browser)
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
VITE_CONTROL_CENTER_PASSWORD=your_admin_password

# Backend — Vercel serverless functions (not exposed to browser)
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Anthropic / Claude AI — scorecard vision + podcast script generation
ANTHROPIC_API_KEY=your_anthropic_api_key
ANTHROPIC_MODEL=claude-opus-4-5-20251001

# Gmail API — email ingestion for scorecard processing
GMAIL_CLIENT_ID=your_gmail_oauth_client_id
GMAIL_CLIENT_SECRET=your_gmail_oauth_client_secret
GMAIL_REFRESH_TOKEN=your_gmail_refresh_token

# ElevenLabs — AI podcast voice synthesis
ELEVENLABS_API_KEY=your_elevenlabs_api_key
ELEVENLABS_HOST_VOICE_ID=your_host_voice_id
ELEVENLABS_COHOST_VOICE_ID=your_cohost_voice_id

# GitHub — podcast episode publishing (optional)
GITHUB_TOKEN=your_github_personal_access_token
